{
  "name": "@workwell/api-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WorkWell TypeScript backend (worker-style) on @mieweb/cloud — Phase 0 skeleton for issue #96 (ADR-008). Replaces the Java/Spring backend incrementally (strangler-fig).",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx node_modules/@mieweb/cli/src/index.mjs --target local dev",
    "start": "tsx src/server.ts",
    "start:local": "tsx node_modules/@mieweb/cli/src/index.mjs --target local dev",
    "migrate:local": "node node_modules/@mieweb/cli/src/index.mjs --target local d1 migrations apply",
    "evaluate": "tsx src/engine/cli/bin.ts",
    "seed:trend-history": "tsx src/run/cli/seed-trend-history-bin.ts",
    "seed:scale": "tsx src/run/cli/seed-scale-bin.ts",
    "seed:quality-history": "tsx src/run/cli/seed-quality-history-bin.ts",
    "resolve-valuesets": "tsx src/run/cli/resolve-valuesets-bin.ts",
    "test:official-cases": "tsx src/run/cli/official-cases-bin.ts",
    "webchart:export-devdb": "tsx scripts/webchart-devdb-export.ts",
    "evaluate:webchart-devdb": "tsx src/engine/ingress/webchart/devdb-cli-bin.ts",
    "evaluate:webchart-live": "tsx src/engine/ingress/webchart/live-cli-bin.ts",
    "load:hapi": "tsx scripts/load-hapi-fixtures.ts",
    "webchart:probe-auth": "tsx scripts/webchart-auth-probe.ts",
    "generate:webchart-import": "tsx scripts/generate-webchart-import.ts",
    "compile-measures": "node scripts/compile-measures.mjs",
    "gen-cql": "node --import tsx scripts/gen-cql.mjs",
    "generate:sql": "tsx src/engine/cql/codegen/generate-sql-bin.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@cqframework/cql": "4.0.0-beta.1",
    "@mieweb/cli": "workspace:*",
    "@mieweb/cloud": "workspace:*",
    "@mieweb/cloud-local": "workspace:*",
    "@mieweb/cloud-os": "workspace:*",
    "@mieweb/cloud-types": "workspace:*",
    "better-sqlite3": "^12.0.0",
    "cql-exec-fhir": "^2.1.6",
    "cql-execution": "^3.3.2",
    "fqm-execution": "1.8.5",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "better-sqlite3": "^12.0.0"
    }
  }
}
