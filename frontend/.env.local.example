# Copy to .env.local for local development. Points the frontend at a locally-running
# backend-ts (`cd backend-ts; pnpm dev`, served on :8080 by default).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=WorkWell Measure Studio

# Prefills the login form for local convenience only. Must stay unset/false in production —
# the production frontend build fails if this is "true" (see next.config.ts).
# NEXT_PUBLIC_DEMO_MODE=true
